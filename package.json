{
  "name": "airbnb-clone",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "supabase": "npx -y supabase@latest",
    "db:migrate:sql": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script > prisma/migrations/20260224103000_init_supabase_postgres/migration.sql",
    "db:migrate:data": "node scripts/migrate-mongo-to-postgres.js",
    "db:migrate:verify": "node scripts/verify-migration.js",
    "db:seed": "prisma db seed",
    "build:netlify": "prisma generate && next build",
    "deploy:robotx": "netlify build && netlify deploy --site 288834e5-4fa2-40b6-bc2b-ab686e063887",
    "deploy:robotx:prod": "netlify build && netlify deploy --prod --site 288834e5-4fa2-40b6-bc2b-ab686e063887",
    "deploy:botshare": "netlify build && netlify deploy --site 147defb9-131c-42ca-8375-37ebc8ba5531",
    "deploy:botshare:prod": "netlify build && netlify deploy --prod --site 147defb9-131c-42ca-8375-37ebc8ba5531",
    "deploy:all": "npm run deploy:robotx && npm run deploy:botshare",
    "deploy:all:prod": "npm run deploy:robotx:prod && npm run deploy:botshare:prod"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.5",
    "@prisma/client": "^4.12.0",
    "@supabase/supabase-js": "^2.98.0",
    "@types/date-fns": "^2.6.0",
    "@types/node": "18.15.11",
    "@types/react": "18.0.31",
    "@types/react-dom": "18.0.11",
    "axios": "^1.3.4",
    "bcryptjs": "^3.0.3",
    "date-fns": "^2.29.3",
    "eslint": "8.37.0",
    "eslint-config-next": "13.2.4",
    "framer-motion": "^10.10.0",
    "leaflet": "^1.9.4",
    "mongodb": "^6.21.0",
    "next": "^13.5.6",
    "next-auth": "^4.20.1",
    "next-cloudinary": "^4.1.1",
    "query-string": "^8.1.0",
    "react": "18.2.0",
    "react-date-range": "^1.4.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.43.9",
    "react-icons": "^5.6.0",
    "react-leaflet": "^4.2.1",
    "react-select": "^5.7.2",
    "react-toastify": "^9.1.2",
    "react-world-flags": "^1.5.1",
    "tailwind-scrollbar": "^3.0.0",
    "typescript": "5.0.3",
    "world-countries": "^4.0.0",
    "zustand": "^4.3.7"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.8",
    "@types/bcrypt": "^5.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.3",
    "@types/react-date-range": "^1.4.4",
    "@types/react-world-flags": "^1.4.2",
    "autoprefixer": "^10.4.14",
    "dotenv": "^17.3.1",
    "postcss": "^8.4.21",
    "prisma": "^4.12.0",
    "tailwindcss": "^3.3.1"
  }
}
